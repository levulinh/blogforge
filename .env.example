# OPENROUTER_API_KEY is required — get yours at https://openrouter.ai/keys
# Used for all agents AND image generation
OPENROUTER_API_KEY=your_openrouter_api_key_here

# TAVILY_API_KEY is required — get yours at https://app.tavily.com
TAVILY_API_KEY=your_tavily_api_key_here

# ---------------------------------------------------------------------------
# Model selection (all optional — defaults shown)
# ---------------------------------------------------------------------------

# Default LLM for all agents (any OpenRouter model slug)
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Per-agent model overrides — each falls back to OPENROUTER_MODEL if not set.
# Useful for running a cheaper model for research and a smarter one for writing.
# ORCHESTRATOR_MODEL=anthropic/claude-3.5-sonnet
# RESEARCHER_MODEL=anthropic/claude-3.5-sonnet
# WRITER_MODEL=anthropic/claude-3.5-sonnet
# CRITIC_MODEL=anthropic/claude-3.5-sonnet

# ---------------------------------------------------------------------------
# Reasoning / extended thinking (optional)
# ---------------------------------------------------------------------------
# Enable reasoning for agents whose model supports it on OpenRouter.
# Supported models include: openai/o1, openai/o3*, openai/o4*,
#   deepseek/deepseek-r1*, anthropic/claude-3.7-sonnet,
#   google/gemini-2.5-*, qwen/qwq-*, qwen/qwen3-*, x-ai/grok-3-mini, etc.
# Models NOT in the supported list are silently unaffected.
# Values: low | medium | high  (unset = reasoning disabled)
# OPENROUTER_REASONING_EFFORT=medium

# Example: use DeepSeek R1 with high reasoning for the Orchestrator and Critic
#          while keeping a fast model for Researcher and Writer:
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
# ORCHESTRATOR_MODEL=deepseek/deepseek-r1
# CRITIC_MODEL=deepseek/deepseek-r1
# OPENROUTER_REASONING_EFFORT=high

# ---------------------------------------------------------------------------
# Image generation model (optional)
# ---------------------------------------------------------------------------
# OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview
